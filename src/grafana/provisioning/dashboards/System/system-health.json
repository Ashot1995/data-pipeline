{
  "dashboard": {
    "title": "System Health Overview",
    "uid": "system-health",
    "schemaVersion": 36,
    "version": 1,
    "tags": ["system", "health", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {"from": "now-1h", "to": "now"},
    "templating": {"list": []},
    "panels": [
      {
        "id": 1,
        "title": "Backend Up",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
        "targets": [{"refId": "A", "expr": "up{job=\"backend\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}}}
      },
      {
        "id": 2,
        "title": "PostgreSQL Up",
        "type": "stat",
        "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
        "targets": [{"refId": "A", "expr": "up{job=\"postgres\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}}}
      },
      {
        "id": 3,
        "title": "Redis Up",
        "type": "stat",
        "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
        "targets": [{"refId": "A", "expr": "up{job=\"redis\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"value": null, "color": "red"}, {"value": 1, "color": "green"}]}}}
      },
      {
        "id": 4,
        "title": "DB Pool Total",
        "type": "stat",
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
        "targets": [{"refId": "A", "expr": "db_connection_pool_size{state=\"total\"}", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 5,
        "title": "Records (last 1h)",
        "type": "stat",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3},
        "targets": [{"refId": "A", "datasource": {"type": "postgres", "uid": "postgres"}, "rawQuery": true, "rawSql": "SELECT COUNT(*) AS total FROM sensor_data WHERE stored_timestamp > NOW() - INTERVAL '1 hour'", "format": "table"}],
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 6,
        "title": "Request Rate (backend)",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 3, "w": 12, "h": 6},
        "targets": [{"refId": "A", "expr": "rate(http_requests_total{job=\"backend\"}[1m])", "legendFormat": "{{method}} {{endpoint}}", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      },
      {
        "id": 7,
        "title": "Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 3, "w": 12, "h": 6},
        "targets": [{"refId": "A", "expr": "rate(http_requests_total{job=\"backend\", status=~\"5..\"}[1m])", "legendFormat": "5xx", "datasource": {"type": "prometheus", "uid": "prometheus"}}],
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      }
    ]
  }
}
