# ==============================================================
# .env.example — copy to .env and fill in your values
# cp .env.example .env
# ==============================================================

# ── Database (PostgreSQL / TimescaleDB) ──────────────────────
POSTGRES_DB=sensor_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host port for direct DB access from your machine (e.g., psql, pgAdmin)
# DB_PORT is always 5432 inside containers (internal, hardcoded in docker-compose.yml)
DB_EXTERNAL_PORT=5433

# ── Redis ─────────────────────────────────────────────────────
REDIS_DB=0
CACHE_TTL=60

# ── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8001
LOG_LEVEL=INFO
# REQUIRED: generate with: openssl rand -hex 32
# The application will refuse to start if this is not set.
JWT_SECRET_KEY=change-me-in-production

# ── Authentication (optional) ─────────────────────────────────
ENABLE_AUTH=false
API_KEYS=

# ── Rate Limiting (optional) ──────────────────────────────────
ENABLE_RATE_LIMITING=false
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Data Generator ────────────────────────────────────────────
DEVICE_ID=sim-01
INTERVAL_SECONDS=5
BASE_TEMPERATURE=23.0
BASE_HUMIDITY=45.0
BASE_GAS=150.0

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Anomaly Detection ─────────────────────────────────────────
ANOMALY_WINDOW_SIZE=100
ANOMALY_THRESHOLD=3.0

# ── MQTT (optional — enable with: docker compose --profile mqtt up) ──
MQTT_ENABLED=false
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=sensors/data

# ── Kafka (optional — enable with: docker compose --profile kafka up) ──
KAFKA_ENABLED=false
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=sensor-data
